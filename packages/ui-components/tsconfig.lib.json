{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "../../tmp/tsc/ui-components.tsbuildinfo",
    "jsx": "react-jsx",
    "baseUrl": "../../",
    "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts"],
    "lib": ["dom", "dom.iterable", "esnext"],
    "paths": {
      "@job-tracker/data-access": ["packages/data-access/src/index.ts"],
      "@job-tracker/hooks": ["packages/hooks/src/index.ts"],
      "@job-tracker/domain": ["packages/domain/src/index.ts"],
      "@job-tracker/validation": ["packages/validation/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx"
  ]
}
